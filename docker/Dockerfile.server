FROM rust:1.82-slim AS builder
WORKDIR /build
COPY crates/ crates/
RUN cd crates/htp-server && cargo build --release

FROM debian:bookworm-slim AS runtime
RUN apt-get update && apt-get install -y ca-certificates && rm -rf /var/lib/apt/lists/*
WORKDIR /app
COPY --from=builder /build/crates/target/release/htp-server /app/htp-server
COPY public/ /app/public/
ENV PORT=3000
ENV HTP_HOST=0.0.0.0
EXPOSE 3000
CMD ["/app/htp-server"]
