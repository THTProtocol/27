{
  "version": 2,
  "builds": [
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "https://hightable.pro/api/$1"
    },
    {
      "src": "/ws",
      "dest": "https://hightable.pro/ws"
    },
    {
      "src": "/health",
      "dest": "https://hightable.pro/health"
    },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}
