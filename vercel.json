{
  "version": 2,
  "builds": [{ "src": "public/**", "use": "@vercel/static" }],
  "routes": [
    { "src": "/api/(.*)", "dest": "https://hightable.pro/api/$1" },
    { "src": "/ws", "dest": "https://hightable.pro/ws" },
    { "src": "/(.*)", "dest": "/public/$1" },
    { "src": "/", "dest": "/public/index.html" }
  ]
}
