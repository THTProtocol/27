# High Table Protocol — Environment Configuration

# Server
PORT=3000
HTP_NETWORK=tn12

# Kaspa RPC (public REST API — safest default)
KASPA_REST_URL=https://api-tn12.kaspa.org
KASPA_WRPC_URL=ws://localhost:17211
MAINNET_API=https://api.kaspa.org

# Protocol
PROTOCOL_ADDRESS=kaspatest:<your-treasury-address>
PROTOCOL_FEE_BPS=200
AUTO_RESOLVE=true

# Oracle (generate with: openssl rand -hex 32)
ORACLE_KEY_1=<64-char-hex>
ORACLE_KEY_2=<64-char-hex>
ORACLE_KEY_3=<64-char-hex>
ORACLE_CHECK_MS=30000
INDEXER_POLL_MS=5000

# CORS
ALLOWED_ORIGINS=https://hightable420.web.app,https://hightable420.firebaseapp.com

# Guardian
HTP_GUARDIAN_ADDRESS=kaspatest:<your-address>