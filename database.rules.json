{
  "rules": {
    ".read": true,
    ".write": true,
    "matches": {
      "$matchId": {
        ".validate": "newData.hasChildren(['id','status','playerA','playerB'])",
        "status": { ".validate": "newData.isString()" }
      }
    },
    "events": {
      ".indexOn": ["status", "category", "createdAt"]
    },
    "markets": {
      ".indexOn": ["status", "createdAt"]
    },
    "lobby": {
      ".indexOn": ["status", "game", "createdAt"]
    }
  }
}
