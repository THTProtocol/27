{
  "rules": {
    "lobby":   { ".read": true, ".write": true },
    "matches": {
      ".read": true, ".write": true,
      ".indexOn": ["status", "network", "player1", "player2"]
    },
    "events": {
      ".read": true, ".write": "auth != null",
      ".indexOn": ["status", "category"]
    },
    "markets": {
      ".read": true, ".write": "auth != null",
      ".indexOn": ["status"]
    },
    "oracle":  { ".read": true, ".write": true },
    "kaspa":   { ".read": true, ".write": true }
  }
}
