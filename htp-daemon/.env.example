# HTP Daemon — environment configuration
# Copy to .env and fill in values before running

# ── Kaspa network ────────────────────────────────────────────────────────────
# "tn12" for testnet-12, "mainnet" for mainnet
KASPA_NETWORK=tn12

# Direct RPC WebSocket URL (optional — if not set, uses public REST only)
# KASPA_RPC_URL=ws://127.0.0.1:16210

# ── Oracle signing key ────────────────────────────────────────────────────────
# 32-byte hex private key for the oracle signing wallet.
# NEVER the same as a player wallet. NEVER committed to git.
ORACLE_PRIVATE_KEY=

# ── Firebase ──────────────────────────────────────────────────────────────────
# Your Firebase Realtime Database URL
FIREBASE_DB_URL=https://hightable-76401-default-rtdb.europe-west1.firebasedatabase.app

# Path to Firebase service account JSON (downloaded from Firebase Console)
FIREBASE_SERVICE_KEY_PATH=./serviceAccountKey.json

# ── Settlement ────────────────────────────────────────────────────────────────
# How many oracle attestations required to finalize (1 = solo, 3 = hardened)
ORACLE_THRESHOLD=1

# Poll interval for Firebase match/event watchers (milliseconds)
POLL_INTERVAL_MS=5000

# ── Optional: external API keys for oracle resolvers ─────────────────────────
# ODDS_API_KEY=
# COINGECKO_API_KEY=
